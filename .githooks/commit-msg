#!/bin/sh
# Enforces the repo's mandatory commit-message format. Installed by
# ./setup.sh (core.hooksPath = .githooks); bypass with --no-verify.
#
# Exists because the format drifted twice despite being written down: a
# whole session of commits landed with Type values outside the allowed set
# ("feature", "fix", "chore") and with no Co-Authored-By trailer at all.
msg="$1"
body=$(grep -v '^#' "$msg")
fail() { printf '\ncommit-msg: %s\n\n' "$1" >&2; exit 1; }

type_line=$(printf '%s\n' "$body" | grep -c '^Type: ')
[ "$type_line" -eq 1 ] || fail "need exactly one 'Type:' line (found $type_line).
  Allowed: bug fix | improvement | new idea | rejection/revert | cosmetic |
           docs | tooling | benchmark"

t=$(printf '%s\n' "$body" | sed -n 's/^Type: //p')
case "$t" in
  "bug fix"|"improvement"|"new idea"|"rejection/revert"|"cosmetic"|"docs"|"tooling"|"benchmark") ;;
  *) fail "Type: '$t' is not allowed.
  Use one of: bug fix | improvement | new idea | rejection/revert |
              cosmetic | docs | tooling | benchmark" ;;
esac

printf '%s\n' "$body" | grep -q '^Co-Authored-By: ' || \
  fail "missing the Co-Authored-By trailer (must come after everything)."

# The Type line is the last line of the BODY -- only trailers may follow.
printf '%s\n' "$body" | awk '
  /^Type: /       { seen = 1; next }
  seen && NF && !/^[A-Za-z-]+: / { bad = 1 }
  END             { exit bad ? 1 : 0 }' || \
  fail "'Type:' must be the last body line -- only trailers may follow it."

# A Benchmark block, when present, uses the FIXED field layout. Checking the
# header spelling and a couple of mandatory fields catches invented layouts
# (the v53 commit used Campaign:/Slices:/Pooled: and dropped Range/Ptnml).
# Trigger on a STANDALONE header line only. Matching any line that merely
# starts with the word is a false positive waiting to happen -- prose wraps,
# and this hook's own commit message tripped it with "Benchmark field names."
if printf '%s\n' "$body" | grep -qE '^Benchmark:?[[:space:]]*$'; then
  printf '%s\n' "$body" | grep -q '^Benchmark$' || \
    fail "Benchmark header takes no colon -- write 'Benchmark', not 'Benchmark:'."
  for f in "Against:" "Games:" "Elo:" "Ptnml:"; do
    printf '%s\n' "$body" | grep -q "^$f" || \
      fail "Benchmark block is missing the mandatory '$f' field.
  Fixed layout: Against / Games / Wins / Draws / Losses / TC / Elo /
  Normalized Elo / Range / Pairs scored / Ptnml / Game pair ratio / SPRT"
  done
  printf '%s\n' "$body" | grep '^Elo:' | grep -q '+/-' || \
    fail "'Elo:' must always carry its error margin (e.g. 'Elo: +37.52 +/- 6.3')."
fi
exit 0
