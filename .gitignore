# ======================================================================
# Pygin .gitignore
# Compiled C artifacts are rebuilt by setup.sh; everything below is either a
# build product, local data, a large third-party file, or NOT part of the
# engine (other apps / private analysis).  NOTHING with credentials is tracked.
# ======================================================================

# --- built C libraries (rebuilt from the .c sources by setup.sh) ---
*.so
*.o
*.dylib
build/

# --- Python bytecode ---
__pycache__/
*.pyc
*.pyo

# --- match / benchmark output (local, per-run) ---
*_vs_*.txt
*_vs_*.pgn
*.pgn
nps_history_results_*.json
nps_history_results_*.md
profile_report.html
*.log

# --- large third-party opening books / nets (download separately) ---
UHO_*.epd
# ...except the default match.py book, which is kept in the repo:
!UHO_4060_v4.epd
# FI-15: the NNUE datagen book ships COMPRESSED (174 MB raw > GitHub's
# 100 MB limit; the .gz is 41 MB). setup.sh auto-extracts the plain .epd,
# which stays ignored via UHO_*.epd above.
!UHO_Lichess_4852_v1.epd.gz
*.bin
# ...except the default opening book (Perfect 2023, freeware, 50 KB):
!Perfect2023.bin
Elo2400.bin

# --- NEVER publish: private / credential-bearing helper (chess.com cookies) ---
chesscom_analysis.py
*secret*
*token*
*.key
.env

# --- not part of the headless engine (GUIs, other sub-projects, experiments) ---
gui.py
gui_pypy.py
main.py
experiment.py
engine_subproc.py
pypy_client.py
engine_battle*.py
engine_cy*
fastboard*
chess_bitboard.py
bench_interp.py
engine_test.py
engine_smp4.py
engine_outpost.py
engine_space.py
engine_phalanx.py
engine_storm.py
engine_shelter.py
engine_combined.py
WebChess/
Chess/
ChessAnalyzer/
cutechess/
AllIn1/
Mephisto-3.0.0/
Testing/
PGN/
New logs/
logs/
claudechess/

# macOS Finder metadata
.DS_Store

# local tooling / non-release engines
.claude/
Bad Engine/

# --- not needed to run benchmarks or headless games (kept local) ---
uci.py
lichess/
lichess_bot.js
lichess-big3-resolved.book
selfplay.py
selfplay/
snapshot_v1/
tune.py
param_sweep.py
tuning_config.json
tactics.py
tc_ab.py
score_positions.py
start.py
test.py
main.c
run_engine.sh
ClaudeChess.command
paintball-app
claudechess
stockfish-18-asm.js
openings.epd
quiet-labeled.v7.epd
wdl_training_data.csv
*.book
elo.md
audit_engine_*.md
improvements_*.md
improvements.md
final_improvements.md

# attic/: dead code archived out of the root (was individually gitignored before the move)
attic/

# --- decluttered from GitHub 2026-07-13 (kept LOCAL, untracked): one-off A/B
# artifacts, orphaned tuner configs, a superseded bench, alt opening books, and
# an accidental nested project dump inside snapshot 12. (.bin already covered
# by *.bin above.) ---
engine_qtt_off.py
cbench.py
tune_config.json
tune_smoke.json
/Old Engine/12/everything/

# PyInstaller output (build_exe.sh); build/ is ignored above
dist/

# --- Only "Old Engine/" and "NNUE/" are tracked folders; ignore every other
# top-level directory (side projects, logs, build output, caches, GUIs).
# Root-level source files stay tracked -- this matches directories only. New
# folders are auto-ignored. (User request 2026-07-11; NNUE added 2026-07-18.)
/*/
!/Old Engine/
!/NNUE/
# FI-15: NNUE code/docs are tracked; datasets, checkpoints, weight files and
# the training venv are local-only (large binaries, PUBLIC repo).
NNUE/datasets/
NNUE/checkpoints/
NNUE/nets/
NNUE/venv/
*.nnue
*.pygdata

# worst-move troll wrappers (local only)
worse_cengine.py
worstfish.py
coinflip.py
drawfish.py

# lichess bot userscript (local only; talks to a local 127.0.0.1 bridge)
lichess_bot_pygin.js

# opening-book output (local only; make_book.py itself is tracked)
book.bin
book.log
patch_book_startpos.py
# downloaded / converted books -- large binaries, keep out of git
*.db3
*.obs.db3.zip

# local security/bug audit of the Mephisto extension -- contains the unpacked ext-id; this repo is PUBLIC
fixes_Mephisto.md

*MC5*
fetch_gg.py
!NNUE/datasets/README.md

# NNUE personal operating guide (local-only; NNUE/README.md is the tracked doc)
nnue_readme.md

# Texel tuning artefacts (texel.py itself is tracked). The extracted position
# set is 375 MB of derived data and stays local. engine_tuned.py is TRACKED:
# it is how an eval candidate reaches the A/B servers (git checkout, then
# `texel.py stage` there -- the .so files are -mcpu=native and cannot be
# copied between machines). It is still a CANDIDATE, not a release: a
# confirmed tune lands in engine.py by hand.
texel_positions.npy
